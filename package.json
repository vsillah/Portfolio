{
  "name": "my-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:knowledge && next build",
    "build:knowledge": "tsx scripts/build-chatbot-knowledge.ts",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "db:health-check": "tsx scripts/database-health-check.ts",
    "db:health-check:update": "tsx scripts/database-health-check.ts --update",
    "db:health-check:dev": "tsx scripts/database-health-check.ts --dev",
    "db:health-check:dev:update": "tsx scripts/database-health-check.ts --dev --update",
    "staging:publications-parity": "tsx scripts/ensure-publications-experience-parity.ts --env-file .env.staging",
    "printful:webhook": "tsx scripts/printful-setup-webhook.ts",
    "storyboard:assets:schematics": "tsx scripts/generate-storyboard-schematics.ts",
    "storyboard:assets:capture": "tsx scripts/capture-storyboard-assets.ts",
    "storyboard:assets:save-auth": "tsx scripts/save-storyboard-auth.ts",
    "storyboard:assets": "npm run storyboard:assets:schematics && npm run storyboard:assets:capture",
    "storyboard:assets:all": "npm run storyboard:assets:schematics && npm run storyboard:assets:capture -- --videos",
    "prepare": "husky install"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.2",
    "@sparticuz/chromium": "^143.0.4",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.2.0",
    "@supabase/supabase-js": "^2.89.0",
    "@vapi-ai/web": "^2.5.2",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "diff": "^8.0.3",
    "framer-motion": "^10.16.16",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.294.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.12.2",
    "next": "^14.0.4",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "playwright-core": "^1.58.2",
    "react": "^18.2.0",
    "react-calendly": "^4.4.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "stripe": "^14.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.16",
    "dotenv": "^17.2.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.25",
    "husky": "^9.0.11",
    "jsdom": "^28.0.0",
    "pg": "^8.20.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
