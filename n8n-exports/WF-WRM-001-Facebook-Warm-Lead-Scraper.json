          }
        ]
      ]
    },
    "Is Smoke Mode": {
      "main": [
        [
          {
            "node": "Synthetic Smoke Leads",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Scrape FB Friends (Apify)",
            "type": "main",
            "index": 0
          },
          {
            "node": "Scrape FB Groups (Apify)",
            "type": "main",
            "index": 0
          },
          {
            "node": "Scrape FB Post Comments (Apify)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Synthetic Smoke Leads": {
