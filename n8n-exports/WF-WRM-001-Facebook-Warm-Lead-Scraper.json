          },
          {
            "node": "Scrape FB Groups (Apify)",
            "type": "main",
            "index": 0
          },
          {
            "node": "Scrape FB Post Comments (Apify)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Scrape FB Friends (Apify)": {
      "main": [
        [
          {
