# Copy to `.env.staging` (gitignored) and fill with real values.
# Keep Vercel **Preview/Staging** environment variables in sync with this file for any key the deployment uses.

# n8n Cloud (same host for prod and staging; staging uses different webhook paths / workflow IDs)
N8N_BASE_URL=https://amadutown.app.n8n.cloud

# Production webhook URLs from each STAG workflow’s Webhook node (ATAS Staging project)
N8N_WEBHOOK_URL=
N8N_DIAGNOSTIC_WEBHOOK_URL=
N8N_DIAGNOSTIC_COMPLETION_WEBHOOK_URL=
N8N_EBOOK_NURTURE_WEBHOOK_URL=
N8N_LEAD_WEBHOOK_URL=
N8N_PROGRESS_UPDATE_WEBHOOK_URL=

# Outreach / warm lead / VEP / social (optional overrides — see lib/n8n.ts)
N8N_CLG002_WEBHOOK_URL=
N8N_CLG003_WEBHOOK_URL=
N8N_WRM001_WEBHOOK_URL=
N8N_WRM002_WEBHOOK_URL=
N8N_WRM003_WEBHOOK_URL=
N8N_VEP001_WEBHOOK_URL=
N8N_VEP002_WEBHOOK_URL=
N8N_SOC001_WEBHOOK_URL=
N8N_SOC002_WEBHOOK_URL=
N8N_TASK_SLACK_SYNC_WEBHOOK_URL=

# Shared secrets (must match staging app + ingest routes)
N8N_WEBHOOK_SECRET=
N8N_INGEST_SECRET=

# Other app integrations
N8N_ONBOARDING_WEBHOOK_URL=

# n8n Public API (for MCP / automation — do not commit real keys)
N8N_CLOUD_API_KEY=

# Optional: block outbound n8n calls in this environment
# N8N_DISABLE_OUTBOUND=true
# MOCK_N8N=true

# Slack test channel routing (set to "test-" to route test messages to #test-* channels)
# When set, n8n workflows should prefix Slack channel names with this value for test runs.
# N8N_SLACK_CHANNEL_PREFIX=test-

# Cheap LLM for test runs (e.g. gpt-4o-mini instead of gpt-4o)
# N8N_TEST_MODEL=gpt-4o-mini
