# ─────────────────────────────────────────────────────────────────────────────
# AmaduTown Portfolio — Environment Variables
# Copy to .env.local and fill in real values:  cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment indicator ────────────────────────────────────────────────────
# Values: development | staging | production
# - development — local; banner "dev". Keep MOCK_N8N / N8N_DISABLE_OUTBOUND below for safe defaults.
# - staging — integration/staging host; banner "staging". Omit MOCK_N8N and N8N_DISABLE_OUTBOUND
#   in Vercel to default to REAL n8n (see lib/n8n-runtime-flags.ts, docs/staging-environment.md).
# - production — live site; no banner when set to production.
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin

# ── Supabase (DEV — used by the app at runtime) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

# ── Supabase PRODUCTION (health checks only — never used by the app) ────────
# The pre-push hook defaults to these so it guards production data.
PROD_SUPABASE_URL=https://YOUR_PROD_PROJECT.supabase.co
PROD_SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use TEST keys locally. Live keys go in Vercel Production env vars only.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Printful ─────────────────────────────────────────────────────────────────
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=
PRINTFUL_WEBHOOK_SECRET=
AMADUTOWN_LOGO_URL=https://your-logo-url.com/logo.png

# ── n8n ──────────────────────────────────────────────────────────────────────
# When MOCK_N8N / N8N_DISABLE_OUTBOUND are omitted, tier defaults apply:
#   staging + production → both OFF (real n8n). development → both OFF unless you set them.
# Override anytime: MOCK_N8N=true|false, N8N_DISABLE_OUTBOUND=true|false (also 0/1, yes/no).
# GET /api/health returns deploymentTier + n8n.mockEnabled / n8n.outboundDisabled for verification.
# MOCK_N8N=true  → chat/diagnostic return mock responses (no fetch to n8n).
# N8N_DISABLE_OUTBOUND=true → ALL outbound n8n webhook calls are suppressed
#   (fire-and-forget AND request/response). Payloads are logged instead.
#   Use both for local dev to prevent any data leaving to n8n.
MOCK_N8N=true
N8N_DISABLE_OUTBOUND=true
N8N_BASE_URL=https://your-n8n-instance.app.n8n.cloud
N8N_WEBHOOK_URL=
# Lead qualification (e.g. "Lead Research and Qualifying Agent" on n8n Cloud).
# MUST use the Production URL: .../webhook/<uuid> — NOT .../webhook-test/<uuid>
# (webhook-test is editor-only and returns 404 for server-side calls).
N8N_LEAD_WEBHOOK_URL=
N8N_ONBOARDING_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_CLG002_WEBHOOK_URL=
N8N_CLG003_WEBHOOK_URL=
N8N_WRM001_WEBHOOK_URL=
N8N_WRM002_WEBHOOK_URL=
N8N_WRM003_WEBHOOK_URL=
N8N_INGEST_SECRET=
N8N_EBOOK_NURTURE_WEBHOOK_URL=
N8N_VEP001_WEBHOOK_URL=
N8N_VEP002_WEBHOOK_URL=
N8N_TASK_SLACK_SYNC_WEBHOOK_URL=
N8N_PROGRESS_UPDATE_WEBHOOK_URL=
N8N_DIAGNOSTIC_WEBHOOK_URL=
N8N_DIAGNOSTIC_COMPLETION_WEBHOOK_URL=
N8N_PROVISIONING_REMINDER_WEBHOOK_URL=
# N8N_SOC001_WEBHOOK_URL=  (defaults to N8N_BASE_URL/webhook/social-content-extract)
# N8N_SOC002_WEBHOOK_URL=  (defaults to N8N_BASE_URL/webhook/social-content-publish)
N8N_CLOUD_API_KEY=

# ── Vapi (voice AI) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
VAPI_PRIVATE_KEY=

# ── LLM providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
TEST_LLM_PROVIDER=openai
TEST_LLM_MODEL=gpt-4o-mini

# ── Calendly ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_DISCOVERY_CALL_URL=https://calendly.com/your-org/discovery-call
CALENDLY_ONBOARDING_CALL_URL=
