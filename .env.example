# ─────────────────────────────────────────────────────────────────────────────
# AmaduTown Portfolio — Environment Variables
# Copy to .env.local and fill in real values:  cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment indicator ────────────────────────────────────────────────────
# Values: development | staging | production
# - development — local; banner "dev". Keep MOCK_N8N / N8N_DISABLE_OUTBOUND below for safe defaults.
# - staging — integration/staging host; banner "staging". Omit MOCK_N8N and N8N_DISABLE_OUTBOUND
#   in Vercel to default to REAL n8n (see lib/n8n-runtime-flags.ts, docs/staging-environment.md).
# - production — live site; no banner when set to production.
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin

# ── Supabase (DEV — used by the app at runtime) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

# ── Supabase PRODUCTION (health checks only — never used by the app) ────────
# The pre-push hook defaults to these so it guards production data.
PROD_SUPABASE_URL=https://YOUR_PROD_PROJECT.supabase.co
PROD_SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use TEST keys locally. Live keys go in Vercel Production env vars only.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Printful ─────────────────────────────────────────────────────────────────
PRINTFUL_API_KEY=
# Required for sync / orders / shipping / mockups (Dashboard → Stores → URL …/stores/NUMERIC_ID)
PRINTFUL_STORE_ID=
PRINTFUL_WEBHOOK_SECRET=
AMADUTOWN_LOGO_URL=https://your-logo-url.com/logo.png

# ── n8n ──────────────────────────────────────────────────────────────────────
# When MOCK_N8N / N8N_DISABLE_OUTBOUND are omitted, tier defaults apply:
#   staging + production → both OFF (real n8n). development → both OFF unless you set them.
# Override anytime: MOCK_N8N=true|false, N8N_DISABLE_OUTBOUND=true|false (also 0/1, yes/no).
# GET /api/health returns deploymentTier + n8n.mockEnabled / n8n.outboundDisabled for verification.
# MOCK_N8N=true  → chat/diagnostic return mock responses (no fetch to n8n).
# N8N_DISABLE_OUTBOUND=true → ALL outbound n8n webhook calls are suppressed
#   (fire-and-forget AND request/response). Payloads are logged instead.
#   Use both for local dev to prevent any data leaving to n8n.
MOCK_N8N=true
N8N_DISABLE_OUTBOUND=true
N8N_BASE_URL=https://your-n8n-instance.app.n8n.cloud
# Personal API key for the n8n REST API (Settings → API Keys in n8n Cloud).
# Only required for the drift checker script (`npm run n8n:drift-check`) and
# any ops tooling that calls the n8n REST API directly. Leave unset in normal
# app runtimes — the Next.js app never reads this directly.
N8N_API_KEY=
# RAG (Pinecone) webhook — default {N8N_BASE_URL}/webhook/amadutown-rag-query; used by in-app email + n8n SOC/MCH
N8N_RAG_QUERY_WEBHOOK_URL=
# Email RAG: unset = on; false = do not call RAG in outreach/delivery (GET /api/admin/rag-health still probes)
# EMAIL_RAG_ENABLED=false
# Optional: append site chat (same email as lead) to email prompt — off unless explicitly true
# EMAIL_RAG_INCLUDE_SITE_CHAT=true
N8N_WEBHOOK_URL=
# Lead qualification (e.g. "Lead Research and Qualifying Agent" on n8n Cloud).
# MUST use the Production URL: .../webhook/<uuid> — NOT .../webhook-test/<uuid>
# (webhook-test is editor-only and returns 404 for server-side calls).
N8N_LEAD_WEBHOOK_URL=
N8N_ONBOARDING_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_CLG003_WEBHOOK_URL=
N8N_WRM001_WEBHOOK_URL=
N8N_WRM002_WEBHOOK_URL=
N8N_WRM003_WEBHOOK_URL=
N8N_INGEST_SECRET=
N8N_EBOOK_NURTURE_WEBHOOK_URL=
N8N_VEP001_WEBHOOK_URL=
N8N_VEP002_WEBHOOK_URL=
N8N_TASK_SLACK_SYNC_WEBHOOK_URL=
N8N_PROGRESS_UPDATE_WEBHOOK_URL=
N8N_DIAGNOSTIC_WEBHOOK_URL=
# WF-DIAG-COMP (n8n Cloud): production https://amadutown.app.n8n.cloud/webhook/diagnostic-completion — do not fall back to lead intake
N8N_DIAGNOSTIC_COMPLETION_WEBHOOK_URL=
N8N_PROVISIONING_REMINDER_WEBHOOK_URL=
# N8N_SOC001_WEBHOOK_URL=  (defaults to N8N_BASE_URL/webhook/social-content-extract)
# N8N_SOC002_WEBHOOK_URL=  (defaults to N8N_BASE_URL/webhook/social-content-publish)
# N8N_SOC_REGENERATE_IMAGE_WEBHOOK_URL=  (defaults to .../webhook/social-content-regenerate-image; do not point at extract)
# N8N_SOC_REGENERATE_AUDIO_WEBHOOK_URL=  (defaults to .../webhook/social-content-regenerate-audio)
N8N_CLOUD_API_KEY=

# ── Vapi (voice AI) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
VAPI_PRIVATE_KEY=

# ── LLM providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
TEST_LLM_PROVIDER=openai
TEST_LLM_MODEL=gpt-4o-mini

# ── Calendly ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_DISCOVERY_CALL_URL=https://calendly.com/your-org/discovery-call
CALENDLY_ONBOARDING_CALL_URL=
CALENDLY_KICKOFF_MEETING_URL=
CALENDLY_PROGRESS_CHECKIN_URL=
CALENDLY_RENEWAL_REVIEW_URL=
CALENDLY_DELIVERY_REVIEW_URL=
CALENDLY_DISCOVERY_LINK=
CALENDLY_API_KEY=
CALENDLY_WEBHOOK_SIGNING_KEY=

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_OUTREACH_CHANNEL_ID=
SLACK_DM_CHANNEL_ID=
SLACK_CHAT_ESCALATION_WEBHOOK_URL=
SLACK_OUTREACH_DRAFT_WEBHOOK_URL=

# ── Email (Gmail SMTP) ──────────────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=ATAS

# Optional: Resend (transactional sends + deliverability webhooks). When RESEND_API_KEY and
# RESEND_FROM_EMAIL are set, outbound mail uses Resend first and falls back to Gmail SMTP.
# Dashboard → Webhooks → signing secret for POST /api/webhooks/resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# ── USPS Tracking API ───────────────────────────────────────────────────────
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=

# ── Google ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=
GOOGLE_DRIVE_SCRIPTS_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Per-admin Gmail OAuth (Lead Pipeline / Email center flows — “Connect my Gmail” when exposed → drafts in the user’s Gmail)
# Google Cloud Console: OAuth 2.0 Web client; Authorized redirect URI must match exactly.
GOOGLE_GMAIL_OAUTH_CLIENT_ID=
GOOGLE_GMAIL_OAUTH_CLIENT_SECRET=
# e.g. http://localhost:3000/api/admin/oauth/google-gmail/callback (prod: https://your-domain/api/admin/oauth/google-gmail/callback)
GOOGLE_GMAIL_OAUTH_REDIRECT_URI=
# Long random secret (min 24 chars); encrypts refresh tokens at rest (scrypt-derived AES-256-GCM + signed OAuth state)
GMAIL_USER_OAUTH_SECRET=

# ── Gamma (report generation) ───────────────────────────────────────────────
GAMMA_API_KEY=
# Auto-generate audit_summary Gamma deck on audit completion (true = enabled, false = disabled)
AUTO_GENERATE_DIAGNOSTIC_AUDIT_SUMMARY=true

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_REPO=
GITHUB_TOKEN=

# ── Social Content Pipeline ─────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
NEXT_PUBLIC_MARGIN_ALERT_THRESHOLD_PERCENT=20

# ── HeyGen (video generation) ───────────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
HEYGEN_BRAND_VOICE_ID=
HEYGEN_WEBHOOK_SECRET=
HEYGEN_TEMPLATE_ID=

# ── Apify ────────────────────────────────────────────────────────────────────
APIFY_TOKEN=

# ── BuiltWith ────────────────────────────────────────────────────────────────
BUILTWITH_API_KEY=

# ── E2E Testing ──────────────────────────────────────────────────────────────
ADMIN_E2E_EMAIL=
ADMIN_E2E_PASSWORD=
